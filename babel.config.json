{
  "presets": [
    ["@babel/preset-env", { "targets": { "node": "20" } }],
    ["@babel/preset-typescript", { "onlyRemoveTypeImports": true }]
  ],
  "plugins": [
    ["@babel/plugin-proposal-decorators", { "legacy": true }],
    ["@babel/plugin-transform-class-properties", { "loose": true }]
  ],
  "overrides": [
    { "test": ["src/**/*.ts"] }
  ]
}
